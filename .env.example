# TalentOS Environment Variables
# Copy this to .env.local and fill in your real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth / Clerk (if using Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Scheduled jobs and internal integrations
CRON_SECRET=your-cron-secret
CRAWLER_API_KEY=your-crawler-api-key
TALENT_OS_WEBHOOK_SECRET=

# AI providers
AI_PROVIDER=
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
NVIDIA_API_KEY=
NVIDIA_MODEL=

# Gmail OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Microsoft / Teams / SharePoint (optional)
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TALENT_OS_WEBHOOK_URL=
SHAREPOINT_DRIVE_FOLDER=

# Job sources and storage
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
RESUME_STORAGE_PROVIDER=
