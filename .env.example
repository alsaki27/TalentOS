# TalentOS Environment Variables
# Copy this to .env.local and fill in your real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# First admin bootstrap (optional; defaults to admin@skarion.local)
ADMIN_EMAIL=admin@skarion.local

# Auth / Clerk (if using Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Required for every /api/cron/* route configured in vercel.json and any local cron calls.
CRON_SECRET=your-cron-secret

# Internal integrations
CRAWLER_API_KEY=your-crawler-api-key
TALENT_OS_WEBHOOK_SECRET=

# AI providers
AI_PROVIDER=
# Reserved for a future provider. The current AI provider implementations are Anthropic and NVIDIA.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
NVIDIA_API_KEY=
NVIDIA_MODEL=

# AI key encryption (required for the admin AI API key manager)
# Generate a strong random secret: openssl rand -base64 32
AI_KEYS_ENCRYPTION_SECRET=

# Gmail OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Microsoft / Teams / SharePoint (optional)
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TALENT_OS_WEBHOOK_URL=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_FOLDER=

# Job sources and storage
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
# Resume storage provider: "r2" (default, requires R2_* env vars above) or "sharepoint" (requires MS_* env vars above)
RESUME_STORAGE_PROVIDER=
